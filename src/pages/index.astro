---
import BaseLayout from '../layouts/BaseLayout.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import CTABand from '../components/CTABand.astro';
import { site } from '../data/site';

// Local generated images — imported as ES modules so Astro's build pipeline
// emits AVIF + WebP + responsive srcsets automatically.
import deckRivervaleBefore  from '../assets/before-after/deck-rivervale-before.png';
import deckRivervaleAfter   from '../assets/before-after/deck-rivervale-after.png';
import patioEmersonBefore   from '../assets/before-after/patio-emerson-before.png';
import patioEmersonAfter    from '../assets/before-after/patio-emerson-after.png';
import patioParkRidgeBefore from '../assets/before-after/patio-park-ridge-before.png';
import patioParkRidgeAfter  from '../assets/before-after/patio-park-ridge-after.png';

const description =
  'Power washing in Bergen County, NJ. Owner-operated by Ben, Justin & Brady — decks, patios, driveways, and pool surrounds. Quiet, careful, free estimates.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: site.tagline,
  url: site.url,
  telephone: site.contacts.map((c) => c.tel),
  image: `${site.url}/images/hero-placeholder.svg`,
  priceRange: '$$',
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Bergen County, NJ' },
    ...site.towns.map((t) => ({ '@type': 'City', name: `${t}, NJ` })),
  ],
  address: { '@type': 'PostalAddress', addressRegion: 'NJ', addressCountry: 'US' },
  contactPoint: site.contacts.map((c) => ({
    '@type': 'ContactPoint',
    name: c.name,
    telephone: c.tel,
    contactType: 'sales',
    areaServed: 'US-NJ',
    availableLanguage: 'English',
  })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Power Washing Services',
    itemListElement: site.services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title, description: s.short },
    })),
  },
};

// Service narrative — alternating image side. Verified Unsplash photo
// representing work-in-action; swap to a real on-the-job photo when available.
const servicesNarrative = site.services.map((s, i) => ({
  ...s,
  number: String(i + 1).padStart(2, '0'),
  imageSide: i % 2 === 0 ? 'left' : 'right',
  image: 'https://images.unsplash.com/photo-1607113364993-4f639eb54ebb?auto=format&fit=crop&w=1200&q=80',
}));
---
<BaseLayout
  title="B&J Exteriors — Power Washing in Bergen County, NJ"
  description={description}
  path="/"
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO  |  asymmetric, photo-left / type-right
       Single dominant idea: water does the work.
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="grid grid-cols-12 gap-0 min-h-[88vh]">

      <!-- Photo: full bleed left, 5 of 12 cols on md+, full-width on mobile -->
      <div class="col-span-12 md:col-span-5 relative bg-bg-up overflow-hidden order-2 md:order-1 aspect-[4/3] md:aspect-auto">
        <!-- Verified Unsplash. Swap to a real action shot of B&J at work when one is available. Suggested: hot-water wand on concrete or a wood deck mid-spray, ~16:10, natural light. -->
        <img src="https://images.unsplash.com/photo-1718152521364-b9655b8a7926?auto=format&fit=crop&w=2000&q=80" alt="Pressure washing in action on an outdoor surface" class="w-full h-full object-cover" loading="eager" />
        <!-- subtle gradient to ground the type column edge -->
        <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-r from-transparent to-bg hidden md:block" aria-hidden="true"></div>
        <!-- metadata stamp -->
        <div class="absolute bottom-5 left-5 md:bottom-8 md:left-8">
          <p class="label !text-bone-soft">Frame / 048 — Hillsdale, NJ</p>
        </div>
      </div>

      <!-- Type column -->
      <div class="col-span-12 md:col-span-7 flex flex-col justify-between px-5 sm:px-8 lg:px-12 py-12 md:py-16 order-1 md:order-2">

        <!-- Top mono row -->
        <div class="flex items-center justify-between" data-reveal>
          <p class="label">N° 00 — index</p>
          <p class="label hidden sm:block">Bergen Co · NJ · est. 2021</p>
        </div>

        <!-- The thing itself -->
        <div class="py-12 md:py-0" data-reveal style="--idx:1">
          <h1 class="d-01 text-balance max-w-[14ch]">
            Strip off everything the weather put there.
          </h1>
          <p class="mt-8 text-bone-soft text-lg md:text-xl max-w-measure">
            {site.tagline}. Owner-operated by three guys — Ben, Justin, and Brady — covering decks, patios, driveways, and pool surrounds across Bergen County.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <a href="/contact" class="btn">
              Get a quote
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17 17 7M9 7h8v8"/>
              </svg>
            </a>
            <a href={`tel:${site.contacts[0].tel}`} class="link-arrow text-base">
              or call {site.contacts[0].name} — {site.contacts[0].phone}
              <span class="arrow">↗</span>
            </a>
          </div>
        </div>

        <!-- Bottom mono row — running facts as type, not pills/icons -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-3 gap-x-6 pt-8 md:pt-0 border-t border-hairline" data-reveal style="--idx:2">
          {[
            ['00', 'Owner-operated'],
            ['01', 'Free estimates'],
            ['02', 'Same-week scheduling'],
            ['03', 'Fully insured'],
          ].map(([num, txt]) => (
            <div class="pt-4">
              <p class="label">{num}</p>
              <p class="text-bone text-sm mt-1.5">{txt}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICES  |  vertical narrative, alternating image side
       Three services. Each gets its own full-section moment.
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-y-6 gap-x-6 mb-16 md:mb-24">
        <div class="col-span-12 md:col-span-5" data-reveal>
          <p class="label mb-4">N° 01 — work</p>
          <h2 class="d-02">What we wash.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 md:pt-3" data-reveal style="--idx:1">
          <p class="text-bone-soft text-lg max-w-measure">
            Three families of jobs covering most of what gets ugly outside. The right pressure, the right chemistry, the right person walking your property.
          </p>
        </div>
      </div>

      <div class="space-y-24 md:space-y-32">
        {servicesNarrative.map((s) => (
          <article class="grid grid-cols-12 gap-6 md:gap-10 items-end" data-reveal>
            <!-- Image -->
            <div class:list={[
              'col-span-12 md:col-span-6 relative aspect-[5/4] bg-bg-up overflow-hidden',
              s.imageSide === 'right' ? 'md:order-2 md:col-start-7' : 'md:order-1',
            ]}>
              <!-- PLACEHOLDER — replace with a hero photo for {s.title} -->
              <img src={s.image} alt={`${s.title} — example work`} loading="lazy" class="w-full h-full object-cover" />
              <p class="absolute bottom-4 left-4 label !text-bone bg-bg/65 px-2 py-1">N° {s.number}</p>
            </div>

            <!-- Type -->
            <div class:list={[
              'col-span-12 md:col-span-5',
              s.imageSide === 'right' ? 'md:order-1' : 'md:order-2 md:col-start-8',
            ]}>
              <p class="label mb-3">Service / {s.number}</p>
              <h3 class="d-03">{s.title}</h3>
              <p class="mt-5 text-bone-soft text-base md:text-lg max-w-measure">{s.description}</p>
              <a href={`/services#${s.slug}`} class="link-arrow mt-7 inline-flex">
                See what's included
                <span class="arrow">↗</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BEFORE / AFTER  |  one dominant pair, not a grid
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-y-6 gap-x-6 mb-12">
        <div class="col-span-12 md:col-span-6" data-reveal>
          <p class="label mb-4">N° 02 — proof</p>
          <h2 class="d-02 max-w-[16ch]">The dirt is real. So's the difference.</h2>
        </div>
        <div class="col-span-12 md:col-span-5 md:col-start-8 md:pt-3" data-reveal style="--idx:1">
          <p class="text-bone-soft text-base md:text-lg max-w-measure">
            A pressure-washing site without before-and-afters is selling you stories. Here are jobs from this season.
          </p>
          <a href="/gallery" class="link-arrow mt-6 inline-flex">
            See the full set
            <span class="arrow">↗</span>
          </a>
        </div>
      </div>

      <!-- Dominant pair — cedar deck restoration -->
      <BeforeAfter
        beforeSrc={deckRivervaleBefore}
        afterSrc={deckRivervaleAfter}
        label="Cedar deck restoration — Rivervale, NJ"
        index="01 / 05"
      />

      <!-- Secondary pair, half scale — paver + stamped concrete patios -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-hairline mt-px">
        <BeforeAfter
          beforeSrc={patioEmersonBefore}
          afterSrc={patioEmersonAfter}
          label="Paver patio — Emerson, NJ"
          index="02 / 05"
        />
        <BeforeAfter
          beforeSrc={patioParkRidgeBefore}
          afterSrc={patioParkRidgeAfter}
          label="Outdoor patio — Park Ridge, NJ"
          index="03 / 05"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       THE TEAM  |  one image, one statement, three numbers as data
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-x-6 gap-y-10">
        <!-- image -->
        <div class="col-span-12 md:col-span-5 relative aspect-[4/5] bg-bg-up overflow-hidden" data-reveal>
          <!-- Verified Unsplash work-scene placeholder. Caption deliberately does NOT claim the people pictured are Ben, Justin, or Brady — swap to a real candid of the three (mid-job, not lined up) and update caption to "The team — Bergen Co." -->
          <img src="https://images.unsplash.com/photo-1581883579507-019c44b711cb?auto=format&fit=crop&w=1200&q=80" alt="Pressure washer in use at close range" loading="lazy" class="w-full h-full object-cover" />
          <p class="absolute bottom-4 left-4 label !text-bone bg-bg/65 px-2 py-1">Mid-job — Bergen Co.</p>
        </div>

        <!-- type -->
        <div class="col-span-12 md:col-span-6 md:col-start-7 flex flex-col justify-between" data-reveal style="--idx:1">
          <div>
            <p class="label mb-4">N° 03 — who shows up</p>
            <h2 class="d-02 max-w-[18ch]">
              Three owners. Every job, one of us.
            </h2>
            <p class="mt-7 text-bone-soft text-lg max-w-measure">
              No franchise, no crew you've never met. Ben, Justin, and Brady run B&amp;J Exteriors directly. We pick up the phone, walk your property, give you a fair price, and stand behind the work.
            </p>
          </div>

          <!-- contacts as data -->
          <ul class="mt-12 border-t border-hairline">
            {site.contacts.map((c, i) => (
              <li>
                <a href={`tel:${c.tel}`} class="group flex items-baseline justify-between gap-4 py-4 border-b border-hairline hover:!border-wet transition-colors">
                  <span class="flex items-baseline gap-3">
                    <span class="label !text-[0.7rem]">0{i + 1}</span>
                    <span class="text-bone text-base md:text-lg">{c.name}</span>
                  </span>
                  <span class="phone text-base md:text-lg">
                    {c.phone}
                    <span class="inline-block ml-1 transition-transform group-hover:translate-x-[2px] group-hover:-translate-y-[2px]">↗</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TESTIMONIAL  |  one dominant pull-quote, type-led
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-24 md:py-36">
      <div class="grid grid-cols-12 gap-x-6">
        <div class="col-span-12 md:col-span-2" data-reveal>
          <p class="label">N° 04 — said</p>
        </div>
        <div class="col-span-12 md:col-span-9 md:col-start-3" data-reveal style="--idx:1">
          <blockquote class="d-02 text-balance">
            <span class="text-bone-mute">“</span>{site.testimonials[0].quote.replace(/^Ben and Justin/, 'They')}<span class="text-bone-mute">”</span>
          </blockquote>
          <p class="mt-8 label">
            {site.testimonials[0].name} — {site.testimonials[0].town}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICE AREA  |  towns set as type, no pills, no chips
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-y-10 gap-x-6">
        <div class="col-span-12 md:col-span-4" data-reveal>
          <p class="label mb-4">N° 05 — area</p>
          <h2 class="d-02">{site.serviceArea}.</h2>
        </div>
        <div class="col-span-12 md:col-span-7 md:col-start-6" data-reveal style="--idx:1">
          <p class="text-bone-soft text-lg max-w-measure mb-10">{site.serviceAreaLong}</p>
          <ul class="columns-2 sm:columns-3 lg:columns-4 gap-x-8 space-y-1.5 text-bone text-lg">
            {site.towns.map((t) => <li>{t}</li>)}
          </ul>
          <p class="label mt-8">Don't see your town — call. We probably cover it.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    heading="Water, applied with judgment."
    subheading="Free estimate. Most jobs scheduled within a week. We answer the phone."
  />
</BaseLayout>
