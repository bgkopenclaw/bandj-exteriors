---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import { site } from '../data/site';

// Bergen County in-progress shot (replaces prior Unsplash stock).
import aboutHero from '../assets/home/about-hero.png';

// Owner portraits. Add Ben & Justin the same way when their photos arrive.
import bradyPortrait from '../assets/team/brady.png';

// Map contact name → portrait. Entries left null render the placeholder SVG
// (and carry a marked comment for easy follow-up).
const portraits: Record<string, typeof bradyPortrait | null> = {
  Ben: null,
  Justin: null,
  Brady: bradyPortrait,
};

const description =
  'Meet Ben, Justin, and Brady — three Bergen County high school students starting B&J Exteriors. Hands-on, community-focused power washing in Northern NJ.';
---
<BaseLayout
  title="About — B&J Exteriors"
  description={description}
  path="/about"
>
  <!-- PAGE HEAD -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 pt-20 md:pt-28 pb-16 md:pb-24">
      <div class="grid grid-cols-12 gap-y-8 gap-x-6">
        <div class="col-span-12 md:col-span-2">
          <p class="label">Index / 03</p>
        </div>
        <div class="col-span-12 md:col-span-9 md:col-start-3" data-reveal>
          <h1 class="d-01 max-w-[16ch]">
            Three guys. <span class="text-bone-mute">Bergen County, NJ.</span>
          </h1>
          <p class="mt-8 text-bone-soft text-lg md:text-xl max-w-measure">
            B&amp;J Exteriors is owned and operated by Ben, Justin, and Brady. One of us is on every job. That's it. That's the whole company.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BIG ART-DIRECTED HERO -->
  <section class="border-b border-hairline">
    <div class="relative bg-bg-up aspect-[16/9] md:aspect-[16/8] overflow-hidden">
      <!-- GPT-Image-2 generated, Bergen County NJ context (Rivervale/Hillsdale aesthetic). Wand mid-spray on a paver walkway, gloved hand only, no identifiable face. Swap to a real candid of the team at a job site when one's available. -->
      <Picture
        src={aboutHero}
        alt="Power-washing job in progress on a paver walkway at a Bergen County, NJ home"
        formats={['avif', 'webp']}
        widths={[800, 1400, 2000]}
        sizes="100vw"
        loading="eager"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute bottom-5 left-5 md:bottom-8 md:left-8 z-10">
        <p class="label !text-bone-soft">Frame / 001 — at work</p>
      </div>
    </div>
  </section>

  <!-- THE STORY  |  asymmetric, type-led -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-32">
      <div class="grid grid-cols-12 gap-x-6 gap-y-10">
        <div class="col-span-12 md:col-span-3" data-reveal>
          <p class="label mb-4">N° 01 — start</p>
          <h2 class="d-03">How it started.</h2>
        </div>
        <div class="col-span-12 md:col-span-8 md:col-start-5" data-reveal style="--idx:1">
          <div class="space-y-7 text-bone-soft text-lg max-w-measure">
            <p>
              B&amp;J Exteriors is brand new. We're three high school students from Bergen County — Ben, Justin, and Brady — born and raised in these towns, in class just down the road.
            </p>
            <p>
              We started it because we wanted real work, and because we wanted to be useful to the neighborhood we grew up in. School comes first. The business comes right after. Both get our full effort.
            </p>
            <p>
              We take this seriously. Every job gets done the right way: we learn the surface, we use the right pressure, we don't rush, and we don't leave until you've seen the work and you're happy with it.
            </p>
            <p class="text-bone text-xl md:text-2xl !leading-snug pt-4">
              When you hire B&amp;J, you're hiring Ben, Justin, and Brady directly. No franchise. No crew you've never met. Three local kids who care about this town and their word.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE THREE  |  hairline-divided portraits, mono labels -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-y-8 gap-x-6 mb-12 md:mb-20">
        <div class="col-span-12 md:col-span-3" data-reveal>
          <p class="label mb-4">N° 02 — owners</p>
          <h2 class="d-03">The three.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 md:pt-2" data-reveal style="--idx:1">
          <p class="text-bone-soft text-lg max-w-measure">
            Direct lines. Tap to call any of us. Whoever answers handles your job.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-hairline">
        {site.contacts.map((c, i) => {
          const portrait = portraits[c.name];
          return (
            <div class="bg-bg p-6 md:p-8 flex flex-col">
              <div class="aspect-[4/5] bg-bg-up mb-6 overflow-hidden">
                {portrait ? (
                  <Picture
                    src={portrait}
                    alt={`Portrait of ${c.name}, owner of B&J Exteriors`}
                    formats={['avif', 'webp']}
                    widths={[360, 540, 800]}
                    sizes="(min-width: 768px) 30vw, 100vw"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <!-- PLACEHOLDER — head-and-shoulders portrait, save to src/assets/team/{c.name.toLowerCase()}.png, then add to the `portraits` map at the top of this file. -->
                  <img src="/images/hero-placeholder.svg" alt={`Portrait of ${c.name}, owner of B&J Exteriors`} loading="lazy" class="w-full h-full object-cover" />
                )}
              </div>
              <p class="label mb-3">0{i + 1} — owner</p>
              <h3 class="d-03">{c.name}</h3>
              <a href={`tel:${c.tel}`} class="phone text-base mt-3 inline-block">
                {c.phone}
                <span class="ml-1">↗</span>
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- COMMITMENTS  |  hairline rules, not card grid -->
  <section class="border-b border-hairline">
    <div class="mx-auto max-w-[1440px] px-5 sm:px-8 lg:px-12 py-20 md:py-28">
      <div class="grid grid-cols-12 gap-x-6 gap-y-10">
        <div class="col-span-12 md:col-span-3" data-reveal>
          <p class="label mb-4">N° 03 — what we promise</p>
          <h2 class="d-03">Commitments.</h2>
        </div>
        <div class="col-span-12 md:col-span-8 md:col-start-5" data-reveal style="--idx:1">
          <ul class="border-t border-hairline">
            {[
              ['Show up', "On time, when we said. If something changes, we call you — not the other way around."],
              ['Do the work', "No subcontractors, no trainees. One of the three of us is on every job from estimate to final walk-through."],
              ['Stand behind it', "If something isn't right, we make it right. That's what locally owned actually means."],
              ['Stay reachable', "Three direct numbers on the page above. They're our cell phones, not a queue."],
            ].map(([t, d], i) => (
              <li class="grid grid-cols-12 gap-x-6 py-6 border-b border-hairline">
                <span class="col-span-2 md:col-span-1 label">0{i + 1}</span>
                <div class="col-span-10 md:col-span-11">
                  <h3 class="text-bone text-lg md:text-xl mb-1.5">{t}</h3>
                  <p class="text-bone-soft max-w-measure">{d}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    heading="Let's see your property."
    subheading="On-site estimates are free and take about ten minutes. No pressure, no obligation."
  />
</BaseLayout>
