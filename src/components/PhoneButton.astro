---
interface Props {
  name: string;
  phone: string;
  tel: string;
  variant?: 'primary' | 'secondary';
  index?: number;
}
const { name, phone, tel, variant = 'primary', index } = Astro.props;
---
<!--
  Renders a contact as a hairline-divided row, not a button card.
  Tap-to-call target stays the entire row.
-->
<a href={`tel:${tel}`} class="group flex items-baseline justify-between gap-4 py-4 border-t border-hairline hover:!border-wet transition-colors">
  <span class="flex items-baseline gap-3">
    {typeof index === 'number' && (
      <span class="label !text-[0.7rem]">0{index + 1}</span>
    )}
    <span class="text-bone text-lg md:text-xl">{name}</span>
  </span>
  <span class="phone text-base md:text-lg">
    {phone}
    <span class="inline-block ml-1 transition-transform group-hover:translate-x-[2px] group-hover:-translate-y-[2px]">↗</span>
  </span>
</a>
